# ============================================
# 脉脉发帖助手 - 配置模板
# ============================================
# 使用方法：复制本文件为 .env，然后填入真实值
#   cp .env.example .env
# ⚠️  .env 文件包含密钥，已被 .gitignore 排除，不会被提交

# ---------- 日志 ----------
# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ---------- 脉脉发帖（爆料活动） ----------
# 发帖间隔（秒），±30秒随机抖动，默认150秒≈2.5分钟
MAIMAI_POST_INTERVAL=150

# ---------- 闪电观察者 ----------
# 发帖间隔（秒），±30秒随机抖动，默认90秒≈1-2分钟
SHANDIAN_POST_INTERVAL=90
# Pexels API Key（已填默认值，开箱即用）
PEXELS_API_KEY=Dj2cqyLh2jdoeOcBbeo6MvtQusvmLO92oaSZI7y4KPjc7ApXT2OTnkC0

# ---------- MultiPost 多平台发布 ----------
# 发帖间隔（秒），±30秒随机抖动，默认90秒≈1.5分钟
MULTIPOST_POST_INTERVAL=90

# ---------- AI 内容生成 ----------
# DeepSeek 接口（兼容 OpenAI SDK）
AI_API_KEY=sk-xxxxxxxx
AI_MODEL=deepseek-chat
AI_BASE_URL=https://api.deepseek.com

# ---------- 数据库 ----------
# SQLite 数据库文件路径
DB_PATH=media_assistant.db
